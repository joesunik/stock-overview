{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "SSO Server (IntelliJ style)",
            "request": "launch",
            "mainClass": "com.sso.SsoServerApplication",
            "projectName": "backend",
            "vmArgs": "-XX:TieredStopAtLevel=1 -Dspring.profiles.active=local -Dspring.output.ansi.enabled=always -Dfile.encoding=UTF-8"
        }
    ]
}